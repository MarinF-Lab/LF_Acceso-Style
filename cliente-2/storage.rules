rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    /* Imágenes de productos: lectura pública, escritura abierta (el admin
       sube sin Firebase Auth — mismo trade-off documentado en firestore.rules). */
    match /{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }
  }
}
